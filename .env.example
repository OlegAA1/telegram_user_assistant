# Telegram API (https://my.telegram.org)
API_ID=
API_HASH=

# E.164 or local format as you use in Telegram login (needed on first auth)
PHONE=

# JSON array of Telegram user ids allowed to use /ask in private (e.g. your second account).
ASK_SENDER_IDS=[123456789]

# Optional legacy: single id merged into ASK_SENDER_IDS (same meaning as one-element list).
# OWNER_ID=

# JSON arrays: usernames without @ or numeric ids (channels often look like -100...)
SOURCE_CHATS=["some_source_channel"]
TARGET_CHATS=["me"]

# JSON array of substrings (case-insensitive match against message text/caption).
# Used for chats listed only in SOURCE_CHATS (without a per-source rule below).
FILTER_KEYWORDS=["keyword1","keyword2"]

# Optional: different keywords per source chat (JSON array of objects).
# When set, matching chat uses only its "keywords"; FILTER_KEYWORDS applies to SOURCE_CHATS entries without a rule.
# SOURCE_CHATS=["extra_chat_without_rule"]
# SOURCE_KEYWORD_RULES=[{"source":"channel_a","keywords":["release"]},{"source":"-1001234567890","keywords":["CVE"]}]

# Forward the original Telegram message to TARGET_CHATS
FORWARD_ORIGINAL=true

# Call local LLM (Ollama) and send its text reply to TARGET_CHATS
USE_LLM=false

LLM_MODEL=qwen2.5-coder:14b
LLM_API_URL=http://localhost:11434/api/generate

# Hybrid AI: OpenRouter is opt-in for /cloud, /analyze, web/latest intents, and fallback.
ENABLE_CLOUD_FALLBACK=false
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT=60

# Web search layer (stub/interface for now; no external provider is called yet).
ENABLE_WEB_SEARCH=false
WEB_SEARCH_PROVIDER=
WEB_SEARCH_API_KEY=

# Optional: override prompt file path (relative to project root unless absolute)
# PROMPT_FILE=prompts/message_analyzer.txt

# Optional: intent JSON prompt for private assistant mode (plain text without /commands)
# INTENT_PARSER_PROMPT=prompts/intent_parser.txt

# SQLite for /remind (separate from dedup DB)
REMINDER_DB_PATH=data/reminders.sqlite3

# IANA timezone for reminders. Default in code is Europe/Moscow (MSK).
REMINDER_TZ=Europe/Moscow

