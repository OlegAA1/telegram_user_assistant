# Telegram API (https://my.telegram.org)
API_ID=
API_HASH=

# E.164 or local format as you use in Telegram login (needed on first auth)
PHONE=

# JSON array of Telegram user ids allowed to use /ask in private (e.g. your second account).
ASK_SENDER_IDS=[123456789]

# Optional legacy: single id merged into ASK_SENDER_IDS (same meaning as one-element list).
# OWNER_ID=

# JSON arrays: usernames without @ or numeric ids (channels often look like -100...)
SOURCE_CHATS=["some_source_channel"]
TARGET_CHATS=["me"]

# JSON array of substrings (case-insensitive match against message text/caption).
# Used for chats listed only in SOURCE_CHATS (without a per-source rule below).
FILTER_KEYWORDS=["keyword1","keyword2"]

# Optional: different keywords and targets per source chat (JSON array of objects).
# When set, matching chat uses only its "keywords"; FILTER_KEYWORDS applies to SOURCE_CHATS entries without a rule.
# If "targets" is omitted, matching messages go to global TARGET_CHATS.
# SOURCE_CHATS=["extra_chat_without_rule"]
# SOURCE_KEYWORD_RULES_FILE=config/source_keyword_rules.json
# SOURCE_KEYWORD_RULES=[{"source":"channel_a","keywords":["release"],"targets":["me"]},{"source":"-1001234567890","keywords":["CVE"],"targets":["-1009876543210"]}]

# Forward the original Telegram message to TARGET_CHATS
FORWARD_ORIGINAL=true

# Call local LLM (Ollama) and send its text reply to TARGET_CHATS
USE_LLM=false

LLM_MODEL=qwen3.5-ru-assistant
LLM_API_URL=http://100.x.x.x:11434/api/generate
LLM_THINK=false
# Ollama context window for local model calls.
LLM_NUM_CTX=32768

# Hybrid AI: OpenRouter is opt-in for /cloud, /analyze, web/latest intents, and fallback.
ENABLE_CLOUD_FALLBACK=false
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT=60
MAX_CLOUD_REQUESTS_PER_DAY=30
MAX_CLOUD_INPUT_CHARS=12000
MAX_CLOUD_OUTPUT_TOKENS=1000
LOG_CLOUD_USAGE=true

# Web search (Tavily): /search and intent web_search.
ENABLE_WEB_SEARCH=false
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_API_KEY=
WEB_SEARCH_DEPTH=advanced
WEB_SEARCH_TOPIC=general
WEB_SEARCH_TIME_RANGE=month
WEB_SEARCH_AUTO_PARAMETERS=true
WEB_SEARCH_CHUNKS_PER_SOURCE=3
WEB_SEARCH_MAX_RESULTS=8
WEB_SEARCH_TIMEOUT=30

# Crypto prices (Binance public API, no key): /price and "цена btc"
ENABLE_CRYPTO_PRICE=true
BINANCE_BASE_URL=https://api.binance.com
BINANCE_TIMEOUT=30
DEFAULT_CRYPTO_VS_CURRENCY=usdt

# Manual scam check: only in SCAM_CHECK_GROUP_ID (not in private DM). Forward post, then /check.
ENABLE_MANUAL_SCAM_CHECK=true
SCAM_CHECK_GROUP_ID=-1001234567890
SCAM_CHECK_AUTO_ON_LINK=true
ENABLE_LINK_SCAM_CHECK=false
SCAM_CHECK_MAX_LINKS=5
SCAM_CHECK_MAX_SEARCHES_PER_LINK=2
SCAM_CHECK_PENDING_TTL_MINUTES=60
SCAM_CHECK_USE_OPENROUTER=true
SCAM_CHECK_DB_PATH=data/pending_posts.sqlite3

# Optional: override prompt file path (relative to project root unless absolute)
# PROMPT_FILE=prompts/message_analyzer.txt

# Optional: intent JSON prompt for private assistant mode (plain text without /commands)
# INTENT_PARSER_PROMPT=prompts/intent_parser.txt

# SQLite for /remind (separate from dedup DB)
REMINDER_DB_PATH=data/reminders.sqlite3

# IANA timezone for reminders. Default in code is Europe/Moscow (MSK).
REMINDER_TZ=Europe/Moscow

# Daily summaries: archive selected chats locally and send a digest automatically.
ENABLE_DAILY_SUMMARY=false
SUMMARY_CHATS=["-1001234567890","some_group"]
SUMMARY_TARGET_CHAT=-1009876543210
SUMMARY_TIME=21:00
SUMMARY_TZ=Europe/Moscow
SUMMARY_DB_PATH=data/chat_summaries.sqlite3

# Disk safety for raw archived messages.
SUMMARY_RETENTION_DAYS=7
SUMMARY_MAX_DB_MB=500
SUMMARY_STORE_MEDIA=false
SUMMARY_VACUUM_AFTER_CLEANUP=true
SUMMARY_MAX_MESSAGE_CHARS=4000

# Optional final polish through OpenRouter. Local Qwen still does chunking/memory.
# Set false if daily summaries must stay fully local.
SUMMARY_USE_CLOUD_FINAL=true
SUMMARY_CLOUD_MODEL=openai/gpt-4.1-mini
SUMMARY_MAX_CLOUD_INPUT_CHARS=30000
SUMMARY_MAX_OUTPUT_TOKENS=1800

# Script health digest: parse messages like "✅ OK | Script" / "❌ ERROR | Script"
# and send exact counters every 12 hours. If target is empty, the first source chat is used.
ENABLE_SCRIPT_DIGEST=false
SCRIPT_DIGEST_CHATS=["-1001234567890"]
SCRIPT_DIGEST_TARGET_CHAT=
SCRIPT_DIGEST_INTERVAL_HOURS=12
SCRIPT_DIGEST_TZ=Europe/Moscow
SCRIPT_DIGEST_DB_PATH=data/script_runs.sqlite3
SCRIPT_DIGEST_RETENTION_DAYS=30
SCRIPT_DIGEST_TOP_LIMIT=10
